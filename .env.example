# Local runtimes
OLLAMA_HOST=http://localhost:11434
LMSTUDIO_HOST=http://localhost:1234
LLAMACPP_HOST=http://localhost:8080

# Generic OpenAI-compatible local server (vLLM, Jan, etc.) -- optional; skipped when unset.
# Include the /v1 path when the upstream uses that layout (e.g. http://localhost:8000/v1).
OPENAI_COMPAT_HOST=
OPENAI_COMPAT_API_KEY=

# Moonshot AI (Kimi) hosted provider -- optional; provider is skipped when unset.
# Get a key at https://platform.kimi.ai/console/api-keys
MOONSHOT_API_KEY=
MOONSHOT_HOST=https://api.moonshot.ai/v1

# Timeouts (ms)
LOCAL_AI_REQUEST_TIMEOUT_MS=120000
LOCAL_AI_DETECT_TIMEOUT_MS=1500
LOCAL_AI_PULL_TIMEOUT_MS=3600000
